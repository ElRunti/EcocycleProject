@model EcoCycleCore.Models.Usuario // Asegúrate de que el namespace coincida con tu proyecto

@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-success">Mi Perfil Ecocycle</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <!-- Tarjeta de Puntos -->
        <div class="col-md-4 mb-4">
            <div class="card text-white bg-success shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h4 class="card-title mb-3">Mis Puntos Acumulados</h4>
                    <!-- Se extrae el valor de la tabla USUARIOS -->
                    <h1 class="display-3 fw-bold">@Model.PuntosAcumulacion</h1>
                    <p class="card-text mt-3">ˇSigue reciclando y canjea tus puntos por grandes recompensas!</p>
                </div>
            </div>
        </div>

        <!-- Tarjeta de Datos del Perfil -->
        <div class="col-md-8 mb-4">
            <div class="card shadow h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Información Personal</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <!-- Se extraen los datos de la tabla USUARIOS -->
                        <dt class="col-sm-4 text-muted">Nombre:</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Nombre</dd>

                        <dt class="col-sm-4 text-muted">Correo Electrónico:</dt>
                        <dd class="col-sm-8">@Model.Correo</dd>

                        <dt class="col-sm-4 text-muted">Teléfono:</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Telefono) ? "No registrado" : Model.Telefono)</dd>

                        <dt class="col-sm-4 text-muted">Dirección:</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Direccion) ? "No registrada" : Model.Direccion)</dd>

                        <dt class="col-sm-4 text-muted">Tipo de Usuario:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary">@Model.TipoUsuario</span>
                        </dd>

                        <dt class="col-sm-4 text-muted">Miembro desde:</dt>
                        <dd class="col-sm-8">@Model.FechaRegistro?.ToString("dd/MM/yyyy")</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light text-end">
                    <a asp-action="Edit" asp-route-id="@Model.UsuarioId" class="btn btn-outline-dark btn-sm">Editar Perfil</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección de Publicaciones Creadas -->
    <div class="row mt-2">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Mis Publicaciones de Reciclaje</h5>
                    <a asp-controller="Publicaciones" asp-action="Create" class="btn btn-sm btn-light text-dark fw-bold">+ Nueva Publicación</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.Publicaciones != null && Model.Publicaciones.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped mb-0 text-center align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <!-- Se reflejan las columnas de la tabla PUBLICACIONES -->
                                        <th>Fecha</th>
                                        <th>Descripción</th>
                                        <th>Peso (Kg)</th>
                                        <th>Ubicación</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var publicacion in Model.Publicaciones.OrderByDescending(p => p.FechaPublicacion))
                                    {
                                        <tr>
                                            <td>@publicacion.FechaPublicacion?.ToString("dd/MM/yyyy")</td>
                                            <td class="text-start">@publicacion.Descripcion</td>
                                            <td><span class="fw-bold">@publicacion.PesoCantidad</span> kg</td>
                                            <td>@publicacion.Ubicacion</td>
                                            <td>
                                                @{
                                                    var badgeClass = publicacion.Estado.ToLower() switch
                                                    {
                                                        "completado" => "bg-success",
                                                        "pendiente" => "bg-warning text-dark",
                                                        "cancelado" => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@publicacion.Estado</span>
                                            </td>
                                            <td>
                                                <a asp-controller="Publicaciones" asp-action="Details" asp-route-id="@publicacion.PublicacionesId" class="btn btn-sm btn-info text-white">Ver</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <h5 class="text-muted">Aún no has creado ninguna publicación.</h5>
                            <p class="mb-0">ˇSube tus materiales reciclables y empieza a ganar puntos!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@model EcoCycleCore.Models.Entrega

@{
    ViewData["Title"] = "Eliminar entrega";
}

<div class="eco-crud-header mb-4">
    <div class="eco-crud-eyebrow">Recolección</div>
    <h1>Eliminar entrega</h1>
</div>

<div class="alert alert-danger d-flex gap-2 align-items-start">
    <i class="bi bi-exclamation-triangle fs-4"></i>
    <div>
        <strong>żSeguro que quieres eliminar esta entrega?</strong>
        <p class="mb-0">Esta acción no se puede deshacer y no revierte los puntos ya otorgados al ciudadano.</p>
    </div>
</div>

<div class="eco-detail-card">
    <dl class="row mb-0">
        <dt class="col-sm-4">Ciudadano</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Ciudadano.Nombre)</dd>

        <dt class="col-sm-4">Publicación</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Publicacion.Descripcion)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.CentroId)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.CentroId)</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PesoReal)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PesoReal) kg</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.PuntosOtorgados)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.PuntosOtorgados) pts</dd>

        <dt class="col-sm-4">@Html.DisplayNameFor(model => model.FechaEntrega)</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.FechaEntrega)</dd>
    </dl>

    <form asp-action="Delete" class="d-flex gap-2 mt-3">
        <input type="hidden" asp-for="EntregaId" />
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash3 me-1"></i> Sí, eliminar
        </button>
        <a asp-action="Index" class="btn-eco-ghost-light">Cancelar</a>
    </form>
</div>
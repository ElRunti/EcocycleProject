@model EcoCycleCore.Models.Entrega

@{
    ViewData["Title"] = "Editar entrega";
}

<div class="eco-crud-header mb-4">
    <div class="eco-crud-eyebrow">Recolección</div>
    <h1>Editar entrega</h1>
</div>

<div class="eco-form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="EntregaId" />
        <input type="hidden" asp-for="PublicacionId" />
        <input type="hidden" asp-for="CiudadanoId" />
        <input type="hidden" asp-for="PuntosOtorgados" />
        <input type="hidden" asp-for="FechaEntrega" />

        <div class="mb-3">
            <label class="form-label">Ciudadano</label>
            <input class="form-control" value="@Model.Ciudadano?.Nombre" disabled />
        </div>

        <div class="mb-3">
            <label class="form-label">Publicación</label>
            <input class="form-control" value="@Model.Publicacion?.Descripcion" disabled />
        </div>

        <div class="mb-3">
            <label asp-for="CentroId" class="form-label"></label>
            <input asp-for="CentroId" class="form-control" />
            <span asp-validation-for="CentroId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="PesoReal" class="form-label"></label>
            <input asp-for="PesoReal" class="form-control" />
            <span asp-validation-for="PesoReal" class="text-danger"></span>
            <div class="form-text">Si cambias el peso, los puntos otorgados no se recalculan automáticamente aquí.</div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-eco-primary">
                <i class="bi bi-check-circle me-1"></i> Guardar cambios
            </button>
            <a asp-action="Index" class="btn-eco-ghost-light">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
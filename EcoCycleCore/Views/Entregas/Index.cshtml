@model IEnumerable<EcoCycleCore.Models.Entrega>

@{
    ViewData["Title"] = "Entregas";
}

<div class="eco-crud-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="eco-crud-eyebrow">Recolección</div>
        <h1>Entregas</h1>
        <p class="text-muted mb-0">Pesajes registrados y puntos otorgados a cada ciudadano.</p>
    </div>
    <a asp-action="Create" class="btn-eco-primary">
        <i class="bi bi-plus-circle me-1"></i> Nueva entrega
    </a>
</div>

<div class="table-responsive">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Ciudadano</th>
                <th>Publicación</th>
                <th>@Html.DisplayNameFor(model => model.CentroId)</th>
                <th>@Html.DisplayNameFor(model => model.PesoReal)</th>
                <th>@Html.DisplayNameFor(model => model.PuntosOtorgados)</th>
                <th>@Html.DisplayNameFor(model => model.FechaEntrega)</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Ciudadano.Nombre)</td>
                    <td>@Html.DisplayFor(modelItem => item.Publicacion.Descripcion)</td>
                    <td>@Html.DisplayFor(modelItem => item.CentroId)</td>
                    <td>@Html.DisplayFor(modelItem => item.PesoReal) kg</td>
                    <td>
                        <span class="badge rounded-pill" style="background-color: var(--eco-sage); color: var(--eco-forest);">
                            +@Html.DisplayFor(modelItem => item.PuntosOtorgados) pts
                        </span>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.FechaEntrega)</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.EntregaId" class="btn btn-sm btn-outline-success">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.EntregaId" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.EntregaId" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash3"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="eco-empty-state text-center py-5">
        <i class="bi bi-clipboard-check"></i>
        <p class="mt-2 mb-0">Todavía no hay entregas registradas.</p>
    </div>
}
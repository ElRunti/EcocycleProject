@{
    ViewData["Title"] = "Registro";
}

<link rel="stylesheet" href="~/css/register.css" />

<div class="register-container">
    <div class="register-card">

        <h2 class="register-title">Crear Cuenta</h2>
        <p class="register-subtitle">Únete a Ecocycle y sé parte del cambio</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger register-alert">
                @ViewBag.Error
            </div>
        }

        <form method="post">
            <div class="register-form-group">
                <label class="form-label">Nombre completo</label>
                <input type="text" name="nombre" class="form-control register-input" placeholder="Ej. Juan Pérez" required />
            </div>

            <div class="register-form-group">
                <label class="form-label">Correo electrónico</label>
                <input type="email" name="correo" class="form-control register-input" placeholder="tu@correo.com" required />
            </div>

            <div class="register-form-group">
                <label class="form-label">Contraseña</label>
                <input type="password" name="password" class="form-control register-input" placeholder="••••••••" required />
            </div>

            <!-- NUEVO: Selección de Rol -->
            <div class="register-form-group">
                <label class="form-label">¿Cómo deseas participar?</label>
                <!-- Usamos la clase form-select de tu site.css -->
                <select name="tipo_usuario" id="tipoUsuario" class="form-select register-input" required onchange="toggleValidacion()">
                    <option value="Usuario" selected>Ciudadano (Quiero reciclar)</option>
                    <option value="Recolector">Recolector (Quiero recoger material)</option>
                </select>
            </div>

            <!-- NUEVO: Campo de Validación Oculto -->
            <div class="register-form-group" id="campoValidacion" style="display: none;">
                <label class="form-label">Validación (RFC o CURP)</label>
                <input type="text"
                       name="documento_identidad"
                       id="documento_identidad"
                       class="form-control register-input"
                       placeholder="Ingresa tu RFC o CURP" />
                <small class="form-text text-muted" style="font-size: 0.8rem;">Requerido por seguridad para ser recolector oficial.</small>
            </div>

            <button type="submit" class="btn btn-primary register-btn">
                Registrarse
            </button>
        </form>

        <div class="register-footer">
            <span>¿Ya tienes una cuenta?</span>
            <a href="/Auth/Login" class="register-link">
                Inicia sesión aquí
            </a>
        </div>

    </div>
</div>

<!-- NUEVO: Lógica dinámica para mostrar/ocultar el campo -->
<script>
    function toggleValidacion() {
        var selectRol = document.getElementById("tipoUsuario");
        var contenedorValidacion = document.getElementById("campoValidacion");
        var inputDocumento = document.getElementById("documento_identidad");

        // Si el usuario elige "Recolector", mostramos el campo y lo hacemos obligatorio
        if (selectRol.value === "Recolector") {
            contenedorValidacion.style.display = "block";
            inputDocumento.setAttribute("required", "required");
        } else {
            // Si elige "Usuario", ocultamos el campo, quitamos el obligatorio y limpiamos el valor
            contenedorValidacion.style.display = "none";
            inputDocumento.removeAttribute("required");
            inputDocumento.value = "";
        }
    }
</script>
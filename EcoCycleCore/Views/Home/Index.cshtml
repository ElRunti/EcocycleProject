@{
    ViewData["Title"] = "Inicio";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}
<div class="eco-page">

    <!-- HERO -->
    <section class="eco-hero text-center">
        <div class="container">
            <span class="eco-eyebrow"><i class="bi bi-recycle"></i> Recicla con propósito</span>
            <h1 class="mt-3 mx-auto">Cada botella que entregas se convierte en puntos reales</h1>
            <p class="lead mx-auto mt-3">
                Publica tu material reciclable, llévalo a un punto de recolección y obtén
                puntos automáticamente al pesarlo. Canjéalos por recompensas en tiendas aliadas.
            </p>
            <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                <a asp-controller="Publicaciones" asp-action="Create" class="btn-eco-primary">
                    <i class="bi bi-plus-circle me-1"></i> Publicar material
                </a>
                <a asp-controller="Cupones" asp-action="Index" class="btn-eco-ghost">
                    Ver recompensas
                </a>
            </div>
        </div>
    </section>

    <!-- STATS -->
    <div class="container eco-stats">
        <div class="row g-3">
            <div class="col-6 col-lg-3">
                <div class="eco-stat-card">
                    <div class="num">+12,500</div>
                    <div class="label">kg de material reciclado</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="eco-stat-card">
                    <div class="num">+3,200</div>
                    <div class="label">usuarios activos</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="eco-stat-card">
                    <div class="num">+8,900</div>
                    <div class="label">canjes realizados</div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="eco-stat-card">
                    <div class="num">45</div>
                    <div class="label">puntos de recolección</div>
                </div>
            </div>
        </div>
    </div>

    <!-- COMO FUNCIONA -->
    <section class="eco-section">
        <div class="container">
            <div class="eco-section-title text-center mb-5">
                <div class="tag">El proceso</div>
                <h2 class="mt-2">Así funciona EcoCycle</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-3 position-relative">
                    <div class="step-card">
                        <div class="step-icon"><i class="bi bi-camera"></i></div>
                        <h6>1. Publica</h6>
                        <p class="text-muted small mb-0">Sube una foto de tu material reciclable, su peso aproximado y ubicación.</p>
                    </div>
                    <div class="step-connector"><i class="bi bi-arrow-right"></i></div>
                </div>
                <div class="col-md-3 position-relative">
                    <div class="step-card">
                        <div class="step-icon"><i class="bi bi-truck"></i></div>
                        <h6>2. Entrega</h6>
                        <p class="text-muted small mb-0">Llévalo a un punto de recolección cercano.</p>
                    </div>
                    <div class="step-connector"><i class="bi bi-arrow-right"></i></div>
                </div>
                <div class="col-md-3 position-relative">
                    <div class="step-card">
                        <div class="step-icon"><i class="bi bi-clipboard-check"></i></div>
                        <h6>3. Pesaje</h6>
                        <p class="text-muted small mb-0">El centro pesa tu material y registra la entrega en el sistema.</p>
                    </div>
                    <div class="step-connector"><i class="bi bi-arrow-right"></i></div>
                </div>
                <div class="col-md-3">
                    <div class="step-card">
                        <div class="step-icon"><i class="bi bi-gift"></i></div>
                        <h6>4. Canjea</h6>
                        <p class="text-muted small mb-0">Usa tus puntos acumulados para canjear cupones en tiendas aliadas.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MODULOS -->
    <section class="eco-section pt-0">
        <div class="container">
            <div class="eco-section-title text-center mb-5">
                <div class="tag">Gestión</div>
                <h2 class="mt-2">Módulos que te pueden servir</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3">
                    <a asp-controller="Materiales" asp-action="Index" class="module-card">
                        <div class="icon"><i class="bi bi-box-seam"></i></div>
                        <h6>Materiales</h6>
                        <p class="text-muted small">Catálogo de materiales reciclables y sus puntos por kilo.</p>
                        <span class="go">Ver materiales <i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>
                <div class="col-md-6 col-lg-3">
                    <a asp-controller="Usuarios" asp-action="Index" class="module-card">
                        <div class="icon"><i class="bi bi-people"></i></div>
                        <h6>Usuarios</h6>
                        <p class="text-muted small">Cuentas registradas y puntos acumulados.</p>
                        <span class="go">Ver usuarios <i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>
                <div class="col-md-6 col-lg-3">
                    <a asp-controller="Publicaciones" asp-action="Index" class="module-card">
                        <div class="icon"><i class="bi bi-megaphone"></i></div>
                        <h6>Publicaciones</h6>
                        <p class="text-muted small">Material disponible para recolección.</p>
                        <span class="go">Ver publicaciones <i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>
                <div class="col-md-6 col-lg-3">
                    <a asp-controller="Entregas" asp-action="Index" class="module-card">
                        <div class="icon"><i class="bi bi-clipboard-check"></i></div>
                        <h6>Entregas</h6>
                        <p class="text-muted small">Pesajes registrados y puntos otorgados.</p>
                        <span class="go">Ver entregas <i class="bi bi-arrow-right"></i></span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA FINAL -->
    <section class="eco-section pt-0">
        <div class="container">
            <div class="eco-cta text-center">
                <h3>¿Tienes material listo para entregar?</h3>
                <p class="text-muted mb-4">Publícalo ahora y empieza a acumular puntos.</p>
                <a asp-controller="Publicaciones" asp-action="Create" class="btn-eco-primary">
                    <i class="bi bi-plus-circle me-1"></i> Publicar material
                </a>
            </div>
        </div>
    </section>

</div>

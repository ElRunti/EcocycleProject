@model EcoCycleCore.Models.Publicacione
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Crear Publicación";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Nueva Publicación de Reciclaje</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- El UsuarioId oculto leyendo de la sesión -->
                        <input type="hidden" asp-for="UsuarioId" value="@Context.Session.GetString("usuario_id")" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <!-- Se usa MaterialId para vincularlo al modelo correctamente -->
                                <label asp-for="MaterialId" class="form-label fw-bold">Material a reciclar</label>
                                <select asp-for="MaterialId" class="form-select" asp-items="ViewBag.MaterialId" required>
                                    <option value="">-- Selecciona un material --</option>
                                </select>
                                <span asp-validation-for="MaterialId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PesoCantidad" class="form-label fw-bold">Peso / Cantidad (Kg)</label>
                                <input asp-for="PesoCantidad" class="form-control" type="number" step="0.01" placeholder="Ej. 2.5" required />
                                <span asp-validation-for="PesoCantidad" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label fw-bold">Descripción</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Describe los detalles de los materiales..."></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Ubicacion" class="form-label fw-bold">Ubicación de recolección</label>
                            <input asp-for="Ubicacion" class="form-control" placeholder="Dirección o punto de encuentro" required />
                            <span asp-validation-for="Ubicacion" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="UrlImagen" class="form-label fw-bold">URL de la Imagen (Opcional)</label>
                            <input asp-for="UrlImagen" class="form-control" placeholder="https://ejemplo.com/imagen.jpg" />
                            <span asp-validation-for="UrlImagen" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Volver a la lista
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-save"></i> Crear Publicación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model EcoCycleCore.Models.Publicacione

@{
    ViewData["Title"] = "Eliminar Publicación";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger shadow-sm border-danger" role="alert">
                <h4 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>¡Advertencia!</h4>
                <p>¿Estás seguro de que deseas eliminar esta publicación? Esta acción no se puede deshacer.</p>
            </div>

            <div class="card shadow mt-3">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Detalles de la Publicación</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Descripción:</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Descripcion)</dd>

                        <dt class="col-sm-4 text-muted">Peso (Kg):</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.PesoCantidad) kg</dd>

                        <dt class="col-sm-4 text-muted">Ubicación:</dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Ubicacion)</dd>

                        <dt class="col-sm-4 text-muted">Estado:</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Html.DisplayFor(model => model.Estado)</span>
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="PublicacionesId" />
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Eliminar Definitivamente
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>